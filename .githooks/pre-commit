#!/bin/sh
# Pre-commit Hook - AgentIQ / SignApps Platform
# 1. Security scanner (secrets detection)
# 2. Cargo fmt --check + clippy (Rust formatting + lints)
# 3. License policy (cargo deny check licenses, only if Cargo.toml touched)
# 4. TypeScript type check (warn-only unless TSC_STRICT=1)

echo "Running pre-commit checks..."

# Get a list of files that have been added or modified
FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    exit 0
fi

# --- 1. Security scanner ---
SECRET_REGEX="(?i)(password|secret|api_?key|token|bearer|aws_access_key|private_key)\s*[:=]\s*['\"][^'\"]{8,}['\"]"

for FILE in $FILES; do
    if echo "$FILE" | grep -qE "(.lock|.png|.jpg|security_logs.txt|core_prompt.md)$"; then
        continue
    fi
    if git diff --cached "$FILE" | grep -E "^+" | grep -Eq "$SECRET_REGEX"; then
        echo "SECURITY ALERT: Potential secret found in $FILE"
        echo "Hardcoding passwords, tokens, or API keys is strictly forbidden."
        echo "Please use the .env file instead."
        exit 1
    fi
done
echo "Security scan passed."

# --- 2. Cargo fmt + clippy (only if .rs files changed) ---
RUST_FILES=$(echo "$FILES" | grep -E '\.rs$')
if [ -n "$RUST_FILES" ]; then
    echo "Running cargo fmt --check..."
    if ! cargo fmt --all -- --check 2>/dev/null; then
        echo "cargo fmt FAILED: Code not formatted. Run 'cargo fmt --all' and re-commit."
        exit 1
    fi
    echo "cargo fmt passed."

    echo "Running cargo clippy (warn-only, CI is authoritative)..."
    cargo clippy --workspace 2>/dev/null || echo "cargo clippy: warnings found (non-blocking, CI will enforce)."
    echo "cargo clippy check done."
fi

# --- 3. License policy check (only if Cargo.toml files changed) ---
# Politique : voir deny.toml + memory/feedback_license_policy.md
# Usage commercial illimité uniquement — GPL/AGPL/LGPL/SSPL/BSL sont bloqués.
CARGO_TOML_FILES=$(echo "$FILES" | grep -E '(^|/)Cargo\.toml$|(^|/)Cargo\.lock$|(^|/)deny\.toml$')
if [ -n "$CARGO_TOML_FILES" ]; then
    echo "Running cargo deny check licenses (Cargo.toml/Cargo.lock/deny.toml modified)..."
    if ! cargo deny check licenses 2>/dev/null; then
        echo ""
        echo "LICENSE CHECK FAILED: A dependency uses a forbidden license."
        echo "Run 'cargo deny check licenses' to see details."
        echo "Policy: see deny.toml comments and memory/feedback_license_policy.md"
        exit 1
    fi
    echo "License check passed."
fi

# --- 4. TypeScript type check (only if .ts/.tsx files changed) ---
# NOTE: The project has pre-existing TS errors acknowledged via ignoreBuildErrors: true
# in next.config.ts. The check runs in warn-only mode until those are resolved.
# Set TSC_STRICT=1 in your environment to make this check blocking.
TS_FILES=$(echo "$FILES" | grep -E '\.(ts|tsx)$')
if [ -n "$TS_FILES" ]; then
    echo "Running tsc --noEmit..."
    TSC_OUTPUT=$(client/node_modules/.bin/tsc --noEmit --project client/tsconfig.json 2>&1)
    TSC_EXIT=$?
    if [ $TSC_EXIT -ne 0 ]; then
        if [ "${TSC_STRICT:-0}" = "1" ]; then
            echo "$TSC_OUTPUT"
            echo "tsc FAILED: TypeScript errors found. Fix them and re-commit."
            exit 1
        else
            echo "tsc WARNING: TypeScript errors found (warn-only mode, set TSC_STRICT=1 to block)."
        fi
    else
        echo "tsc passed."
    fi
fi

echo "All pre-commit checks passed."
exit 0
