# SignApps Platform - Environment Variables
# Copy this file to .env and fill in the values

# Database
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_jwt_secret_32_chars_minimum

# MinIO (S3-compatible storage)
MINIO_USER=signapps
MINIO_PASSWORD=your_minio_password

# Hugging Face (for vLLM models)
HF_TOKEN=your_huggingface_token

# AI Service Configuration
# Option 1: Ollama (recommended for development, works on CPU)
VLLM_URL=http://ollama:11434
EMBEDDINGS_URL=http://ollama:11434
DEFAULT_MODEL=llama3.2:3b
EMBEDDINGS_MODEL=nomic-embed-text

# Option 2: vLLM + TEI (requires GPU)
# VLLM_URL=http://vllm:8000
# EMBEDDINGS_URL=http://embeddings:8080
# DEFAULT_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Let's Encrypt
ACME_EMAIL=admin@yourdomain.com

# LDAP/Active Directory (optional)
LDAP_URL=ldap://your-dc.domain.local:389
LDAP_BIND_DN=CN=service,OU=Services,DC=domain,DC=local
LDAP_BIND_PASSWORD=your_ldap_password
LDAP_BASE_DN=DC=domain,DC=local
