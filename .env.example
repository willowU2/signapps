# SignApps Platform - Environment Variables
# Copy this file to .env and fill in the values
# For production Docker Compose: copy to .env.prod and set all values below.

# ─── Production deployment ──────────────────────────────────────────────────

# Docker image version tag used by docker-compose.prod.yml
# SIGNAPPS_VERSION=latest

# Database password (used by docker-compose.prod.yml for the postgres container)
# In docker-compose.prod.yml DATABASE_URL is built from this automatically.
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ─────────────────────────────────────────────────────────────────────────────

# Database (auto-detected if PostgreSQL is installed natively)
# DATABASE_URL=postgres://signapps:password@localhost:5432/signapps
DB_PASSWORD=your_secure_password_here

# JWT — two modes supported:
#
# Mode A: RS256 (RECOMMENDED for production — asymmetric, stateless validation)
# Generate keys: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#                openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# On the identity service (set BOTH):
# JWT_PRIVATE_KEY_PEM=<contents of jwt_private.pem>
# JWT_PUBLIC_KEY_PEM=<contents of jwt_public.pem>
# On all other services (set only public key):
# JWT_PUBLIC_KEY_PEM=<contents of jwt_public.pem>
#
# Mode B: HS256 (legacy / development — symmetric shared secret)
# All services must share the same secret.
JWT_SECRET=your_jwt_secret_32_chars_minimum
#
# Note: In RS256 mode JWT_SECRET is ignored for JWT signing/verification.
# If using LDAP integration in RS256 mode, set LDAP_ENCRYPTION_KEY explicitly:
# LDAP_ENCRYPTION_KEY=your_ldap_encryption_key_32chars

# Storage (filesystem by default, S3-compatible optional)
STORAGE_MODE=fs
STORAGE_FS_ROOT=./data/storage
# S3 mode (uncomment for MinIO/AWS S3):
# STORAGE_MODE=s3
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_ACCESS_KEY=signapps
# STORAGE_S3_SECRET_KEY=your_s3_secret
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=signapps

# Hugging Face (for vLLM models)
HF_TOKEN=your_huggingface_token

# AI Service Configuration
# Option 1: Ollama (recommended for development, works on CPU)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDINGS_URL=http://localhost:11434
EMBEDDINGS_MODEL=nomic-embed-text

# Option 2: vLLM + TEI (requires GPU)
# VLLM_URL=http://vllm:8000
# VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
# EMBEDDINGS_URL=http://embeddings:8080

# Option 3: OpenAI API
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Option 4: Anthropic API
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Default LLM provider (ollama, vllm, openai, anthropic)
LLM_PROVIDER=ollama

# Media Services - Native backends (leave empty/unset to use native engines)
# Set URL to use external Docker-based services instead
# STT_URL=http://localhost:8100        # Empty = native whisper-rs
# TTS_URL=http://localhost:10200       # Empty = native piper-rs
# OCR_URL=http://localhost:8101        # Empty = native ocrs

# Native model settings
STT_MODEL=medium                        # whisper model: base, small, medium, large-v3
TTS_VOICE=fr_FR-siwis-medium            # default Piper voice

# Hardware / Model cache
MODELS_DIR=./data/models                # model cache directory
GPU_BACKEND=auto                        # auto, cuda, rocm, metal, vulkan, cpu

# Native LLM (llama-cpp-2 GGUF)
# LLAMACPP_MODEL=                       # model name or path to GGUF file
# LLAMACPP_GPU_LAYERS=auto              # number of GPU layers (auto = based on VRAM)
# LLAMACPP_CONTEXT_SIZE=4096            # context window size

# Voice pipeline
AI_URL=http://localhost:3005/api/v1     # AI service URL for voice WebSocket pipeline

# ─── AI Multimodal Gateway ──────────────────────────────

# Reranker
# RERANKER_URL=                          # TEI reranking endpoint (e.g., http://localhost:8082)
# RERANKER_MODEL=default                 # Reranker model name
# COHERE_API_KEY=                        # Cohere API key for cloud reranker

# Multimodal Embeddings (SigLIP/CLIP)
# MULTIMODAL_EMBED_URL=                  # SigLIP/CLIP HTTP endpoint
# MULTIMODAL_EMBED_MODEL=siglip         # Model name
# MULTIMODAL_EMBED_DIM=1024             # Embedding dimension (1024 for SigLIP-SO400M)

# Vision (Image Analysis / VQA)
# VISION_URL=                            # vLLM/Ollama multimodal endpoint
# VISION_MODEL=default                   # Vision model name
# Note: OPENAI_API_KEY (above) also enables GPT-4o Vision as cloud fallback

# Image Generation
# IMAGEGEN_URL=                          # ComfyUI/Automatic1111 API endpoint
# IMAGEGEN_MODEL=default                 # Default image gen model
# IMAGEGEN_CLOUD_MODEL=dall-e-3         # Cloud model (DALL-E 3)

# Video Generation
# VIDEOGEN_URL=                          # Video generation HTTP service
# VIDEOGEN_MODEL=default                 # Default video model
# VIDEOGEN_CLOUD_MODEL=minimax/video-01 # Cloud model (Replicate)

# Video Understanding
# VIDEO_UNDERSTAND_URL=                  # Video analysis HTTP service
# Note: GEMINI_API_KEY (above) enables Gemini 1.5 Pro for video understanding

# Audio Generation
# AUDIOGEN_URL=                          # Audio generation HTTP service
# AUDIOGEN_MODEL=default                 # Default audio model
# AUDIOGEN_CLOUD_MODEL=meta/musicgen:large  # Cloud model (Replicate)

# Document Parsing
# Note: OCR_URL (above) enables native document parsing
# AZURE_DOC_ENDPOINT=                    # Azure Document Intelligence endpoint
# AZURE_DOC_KEY=                         # Azure Document Intelligence key

# Cloud API Keys (used by multiple multimodal capabilities)
# REPLICATE_API_KEY=                     # Replicate.com API key (video gen, audio gen)
# Note: OPENAI_API_KEY also enables vision, image gen, embeddings
# Note: GEMINI_API_KEY also enables video understanding

# ─── Native Multimodal Models (require feature flags) ───

# Native Reranker (--features native-reranker)
# RERANKER_ONNX_MODEL=data/models/reranker/model.onnx
# RERANKER_ONNX_TOKENIZER=data/models/reranker/tokenizer.json

# Native SigLIP Embeddings (--features native-embedmm)
# SIGLIP_TEXT_MODEL=data/models/siglip/text_model.onnx
# SIGLIP_VISION_MODEL=data/models/siglip/vision_model.onnx
# SIGLIP_TOKENIZER=data/models/siglip/tokenizer.json
# SIGLIP_DIM=1024

# Native Vision (--features native-vision)
# VISION_GGUF_MODEL=                     # Path to multimodal GGUF model
# VISION_CONTEXT_SIZE=4096
# VISION_GPU_LAYERS=-1                   # -1 = auto

# Native Image Generation (--features native-imagegen)
# IMAGEGEN_MODEL_PATH=                   # Path to model directory (safetensors)
# IMAGEGEN_MODEL_TYPE=sdxl               # sd15, sdxl, flux-schnell, flux-dev

# Mail Service
MAIL_SERVICE_URL=http://localhost:3012

# Google OAuth2 for Mail (Gmail IMAP/SMTP via XOAUTH2)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 for Mail (Office 365 IMAP/SMTP via XOAUTH2)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Local mail server (Mailpit) — for dev/testing email capture
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Let's Encrypt
ACME_EMAIL=admin@yourdomain.com

# LDAP/Active Directory (optional)
LDAP_URL=ldap://your-dc.domain.local:389
LDAP_BIND_DN=CN=service,OU=Services,DC=domain,DC=local
LDAP_BIND_PASSWORD=your_ldap_password
LDAP_BASE_DN=DC=domain,DC=local

# Collaborative Documents Service (signapps-docs)
# WebSocket server for Y.js/Yrs real-time collaboration
# Supports: Text, Sheet, Slide, Board
DOCS_URL=http://localhost:3010/api/v1
NEXT_PUBLIC_DOCS_URL=ws://localhost:3010

# ─── Observability ───────────────────────────────────────
# RUST_LOG=info,signapps=debug,sqlx=warn,tower_http=debug
# RUST_LOG_FORMAT=pretty                    # "pretty" (dev) or "json" (production)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # OTLP collector (Jaeger, Datadog, etc.)

# ─────────────────────────────────────────────────────────────
# signapps-keystore — master key for encryption at rest
# ─────────────────────────────────────────────────────────────
# 32 bytes hex-encoded (64 characters). Generate with:
#   bash scripts/generate-master-key.sh
#
# Dev: set via env var (this file).
# Prod: prefer File backend — write the hex to /etc/signapps/master.key
#       with chmod 600, then set KEYSTORE_BACKEND=file and
#       KEYSTORE_MASTER_KEY_FILE=/etc/signapps/master.key.
#
# NEVER commit a real key to git.
KEYSTORE_MASTER_KEY=

# ─────────────────────────────────────────────────────────────
# signapps-oauth — HMAC secret for stateless FlowState tokens
# ─────────────────────────────────────────────────────────────
# 32 bytes hex-encoded (64 characters). Generate with:
#   bash scripts/generate-master-key.sh   # re-uses the key generator
#
# This secret signs the OAuth `state` param. MUST be distinct from
# JWT_SECRET and KEYSTORE_MASTER_KEY. Rotating invalidates any flows
# in progress (callbacks arriving with state signed by the old secret
# will be rejected as BadSignature — acceptable given the 10min TTL).
OAUTH_STATE_SECRET=

# Deploy API (Phase 3a). Set to "true" to activate HTTP endpoints.
DEPLOY_API_ENABLED=false
